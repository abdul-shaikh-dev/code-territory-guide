{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version", "run_id", "case_id", "repo", "arm", "attempt",
    "started_at", "finished_at", "model", "reasoning_effort", "query",
    "execution", "seed", "repository_before", "repository_after",
    "treatment", "evaluation_lock", "events", "raw_output", "tool_log",
    "diff", "changed_files", "provisioned_sha256_after",
    "validation_observed", "exit_status", "excluded"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string"},
    "case_id": {"type": "string"},
    "repo": {"type": "string"},
    "arm": {"enum": ["baseline", "installed-skill"]},
    "attempt": {"type": "integer", "minimum": 1},
    "started_at": {"type": "string"},
    "finished_at": {"type": "string"},
    "model": {"type": "string"},
    "reasoning_effort": {"type": "string"},
    "query": {"type": "string"},
    "execution": {"type": "object"},
    "seed": {"type": "object"},
    "repository_before": {"type": "object"},
    "repository_after": {"type": "object"},
    "treatment": {"type": "object"},
    "evaluation_lock": {"type": "object"},
    "events": {"type": "array"},
    "raw_output": {"type": "string"},
    "tool_log": {"type": "string"},
    "diff": {"type": "string"},
    "changed_files": {"type": "array"},
    "provisioned_sha256_after": {"type": "object"},
    "validation_observed": {"type": "object"},
    "exit_status": {"type": ["integer", "null"]},
    "excluded": {"type": "object"}
  },
  "additionalProperties": true
}
