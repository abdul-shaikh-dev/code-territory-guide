{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Code Territory Guide materialized behavioral evaluation run",
  "type": "object",
  "required": [
    "schema_version", "run_id", "case_id", "arm", "attempt", "started_at", "finished_at",
    "harness", "model", "reasoning_effort", "routing_sha256", "query", "fixture",
    "treatment", "raw_output", "tool_log", "worktree_before", "worktree_after", "diff",
    "files_before", "files_after", "changed_files", "tool_events", "repository_before",
    "repository_after", "exit_status", "excluded"
  ],
  "properties": {
    "schema_version": {"enum": [2, 3]},
    "run_id": {"type": "string"},
    "case_id": {"type": "string"},
    "arm": {"enum": ["baseline", "installed-skill"]},
    "attempt": {"type": "integer", "minimum": 1},
    "started_at": {"type": "string"},
    "finished_at": {"type": "string"},
    "harness": {"type": "string"},
    "harness_revision": {"type": "string"},
    "execution_mode": {"type": "string"},
    "execution_authorization": {"type": "object"},
    "model": {"type": "string"},
    "reasoning_effort": {"enum": ["low", "medium", "high", "xhigh", "max", "ultra"]},
    "routing": {"type": "object"},
    "routing_sha256": {"type": "string"},
    "evaluation_lock": {
      "type": "object",
      "required": ["release_id", "sha256", "preregistered"],
      "properties": {
        "release_id": {"type": "string"},
        "sha256": {"type": "string"},
        "preregistered": {"const": true}
      },
      "additionalProperties": false
    },
    "query": {"type": "string"},
    "fixture": {"type": "object"},
    "treatment": {"type": "object"},
    "raw_output": {"type": "string"},
    "tool_log": {"type": "string"},
    "worktree_before": {"type": "string"},
    "worktree_after": {"type": "string"},
    "diff": {"type": "string"},
    "files_before": {"type": "object"},
    "files_after": {"type": "object"},
    "changed_files": {"type": "array"},
    "tool_events": {"type": "array"},
    "repository_before": {"type": "object"},
    "repository_after": {"type": "object"},
    "exit_status": {"type": ["integer", "null"]},
    "excluded": {"type": "object"}
  },
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"const": 3}}},
      "then": {"required": ["evaluation_lock", "harness_revision", "execution_mode", "execution_authorization", "routing"]}
    }
  ],
  "additionalProperties": false
}
